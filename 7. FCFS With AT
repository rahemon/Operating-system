#include<stdio.h>
int main(){
int at[15],bt[15],ct[15],wt[15],tat[15],rt[15],start[15],i,n;
printf("Enter the number of process:");
scanf("%d",&n);
printf("Enter arrival time of all the processes:");
for(i=0;i<n;i++)
scanf("%d",&at[i]);

printf("Enter burst time of all the processes:");
for(i=0;i<n;i++)
scanf("%d",&bt[i]);

start[0]=at[0];
ct[0]=start[0]+bt[0];

for(i=1;i<n;i++){
    if(at[i]>ct[i-1])
        start[i]=at[i];
    else
        start[i]=ct[i-1];
    ct[i]=start[i]+bt[i];
}

float totalwt=0,totaltat=0;
for(i=0;i<n;i++){
    tat[i]=ct[i]-at[i];
    wt[i]=tat[i]-bt[i];

    totalwt += wt[i];
    totaltat += tat[i];
}
printf("PNo.\tAT\tBT\tCT\tTAT\tWT\n");
for(i=0;i<n;i++)
    printf("p%d\t%d\t%d\t%d\t%d\t%d\n",i+1,at[i],bt[i],ct[i],tat[i],wt[i]);
printf("Avg waiting time = %.2f\n",totalwt/n);
printf("Avg turn around time = %.2f\n",totaltat/n);
return 0;
}
